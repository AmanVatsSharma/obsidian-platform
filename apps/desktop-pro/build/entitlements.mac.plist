<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  File:        apps/desktop-pro/build/entitlements.mac.plist
  Module:      desktop-pro · Distribution · macOS Entitlements
  Purpose:     Declares required entitlements for macOS hardened runtime + notarization.
               Both the app and its helpers inherit these via entitlementsInherit.

  Key invariants:
  - cs.allow-jit   — required for Chromium V8 JIT compilation (crashes without it)
  - cs.allow-unsigned-executable-memory — needed for Electron's renderer sandbox
  - network.client — allows outbound TCP for Socket.IO price feed + OMS API calls
  - Without these, the app passes local testing but fails Gatekeeper on end-user machines

  Author:      BharatERP
  Last-updated: 2026-04-26
-->
<plist version="1.0">
  <dict>
    <!-- Allow JIT-compiled code (Chromium V8 — mandatory for Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory pages (Electron sandbox requirement) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow disabling library validation for dynamically-loaded Chromium libs -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Outbound network access (price feed WebSocket + REST OMS) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- File read access for loading layout JSON from userData directory -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
  </dict>
</plist>
