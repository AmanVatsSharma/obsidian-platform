{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "tags": ["type:app", "scope:mobile", "layer:entrypoint"],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start"
      }
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo prebuild"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/mobile/tsconfig.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/mobile/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}
