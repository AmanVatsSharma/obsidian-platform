{
  "name": "apps",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project apps --web",
  "targets": {
    "dev": {
      "command": "next dev -p 4200",
      "options": {
        "cwd": "apps"
      }
    },
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps"
      }
    },
    "start": {
      "command": "next start -p 4200",
      "options": {
        "cwd": "apps"
      }
    }
  }
}