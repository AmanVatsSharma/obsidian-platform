# Broker Admin — Local Dev Environment Variables
# Copy to .env.local and fill in values

# Backend API base URL (no trailing slash)
# The Next.js rewrite proxies /api/* → NEXT_PUBLIC_API_BASE_URL/*
# Leave as-is for local dev with backend on port 3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Default tenant code for local dev when NOT running on a subdomain.
# When running at http://localhost:4500, this is used as the broker code.
# For subdomain dev (http://demo-broker.localhost:4500), this is ignored.
# Use lvh.me for zero-config subdomain dev: http://demo-broker.lvh.me:4500
NEXT_PUBLIC_DEFAULT_TENANT=demo-broker
