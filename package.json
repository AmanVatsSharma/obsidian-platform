{
  "name": "nesttrade",
  "version": "1.0.0",
  "description": "Enterprise-grade Nx monorepo for NestTrade platform",
  "main": "index.js",
  "private": true,
  "scripts": {
    "nx": "nx",
    "dev:web": "nx run web:dev",
    "dev:backend": "nx run backend:serve",
    "dev:dealer": "nx run dealer-workstation:dev",
    "dev:support-ops": "nx run support-ops:dev",
    "dev:ib-portal": "nx run ib-portal:dev",
    "dev:developer-portal": "nx run developer-portal:dev",
    "dev:public-site": "nx run public-site:dev",
    "build": "nx run-many -t build --all",
    "lint": "nx run-many -t lint --all",
    "lint:mobile": "nx run mobile:lint",
    "lint:desktop": "nx run desktop-pro:lint",
    "lint:wave2-surfaces": "nx run-many -t lint --projects=dealer-workstation,support-ops,ib-portal,developer-portal,public-site,mobile,desktop-pro",
    "test": "nx run-many -t test --all",
    "e2e": "nx run web-e2e:e2e",
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "test:contracts": "nx test backend-execution-gateway --runInBand",
    "test:developer-platform-contracts": "nx test backend-developer-platform --runInBand",
    "smoke:desktop": "nx run desktop-pro:lint",
    "check:cycles": "madge --circular --extensions ts apps/backend/src",
    "check:duplicates": "node tools/scripts/check-duplicate-files.mjs",
    "quality:verify": "npm run check:cycles && npm run check:duplicates && npm run test:contracts && npm run test:developer-platform-contracts && npm run affected:lint && npm run affected:test && npm run affected:build",
    "quality:wave2": "npm run lint:wave2-surfaces && npm run lint:mobile && npm run smoke:desktop",
    "docs:api": "cd apps/backend && npx typedoc --options typedoc.json",
    "postinstall": "nx connect"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-sns": "^3.891.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "json2csv": "^6.0.0-alpha.2",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.5",
    "next": "~15.2.4",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "pino": "^9.10.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "redis": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.26",
    "uuid": "^13.0.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@nx/devkit": "21.5.3",
    "@nx/eslint": "^21.5.3",
    "@nx/eslint-plugin": "^21.5.3",
    "@nx/jest": "^21.5.3",
    "@nx/js": "21.5.3",
    "@nx/next": "^21.5.3",
    "@nx/playwright": "21.5.3",
    "@nx/workspace": "^21.5.3",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typedoc": "^0.27.9",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.20.0"
  }
}
