{
  "name": "obsidian",
  "version": "1.0.0",
  "description": "Enterprise-grade Nx monorepo for Obsidian platform",
  "main": "index.js",
  "private": true,
  "scripts": {
    "nx": "nx",
    "dev:web": "nx run web:dev",
    "dev:backend": "bash -c 'export NODE_OPTIONS=\"--require $(pwd)/path-register.js\" && nx run backend:serve'",
    "dev:dealer": "nx run dealer-workstation:dev",
    "dev:support-ops": "nx run support-ops:dev",
    "dev:ib-portal": "nx run ib-portal:dev",
    "dev:developer-portal": "nx run developer-portal:dev",
    "dev:public-site": "nx run public-site:dev",
    "dev:broker-admin": "nx run broker-admin:dev",
    "dev:platform-owner": "nx run platform-owner:dev",
    "build": "nx run-many -t build --all",
    "lint": "nx run-many -t lint --all",
    "lint:mobile": "nx run mobile:lint",
    "lint:desktop": "nx run desktop-pro:lint",
    "lint:wave2-surfaces": "nx run-many -t lint --projects=dealer-workstation,support-ops,ib-portal,developer-portal,public-site,mobile,desktop-pro",
    "test": "nx run-many -t test --all",
    "e2e": "nx run web-e2e:e2e",
    "affected:lint": "nx run-many -t lint --projects=backend,backend-auth,backend-rbac,backend-tenancy,backend-oms,backend-market,backend-accounts,broker-admin,web --skip-nx-cache",
    "affected:test": "nx affected -t test",
    "test:contracts": "nx test backend-execution-gateway --runInBand",
    "test:developer-platform-contracts": "nx test backend-developer-platform --runInBand",
    "dev:desktop": "nx run desktop-pro:serve",
    "smoke:desktop": "nx run desktop-pro:lint",
    "check:cycles": "madge --circular --extensions ts apps/backend/src",
    "check:duplicates": "node tools/scripts/check-duplicate-files.mjs",
    "check:headers": "node tools/scripts/check-file-headers.mjs",
    "scaffold:module-doc": "node tools/scripts/scaffold-module-doc.mjs",
    "quality:verify": "npm run check:cycles && npm run check:duplicates && npm run check:headers && npm run test:contracts && npm run test:developer-platform-contracts && npm run affected:lint && npm run affected:test && npm run affected:build",
    "quality:wave2": "npm run lint:wave2-surfaces && npm run lint:mobile && npm run smoke:desktop",
    "docs:api": "cd apps/backend && npx typedoc --options typedoc.json",
    "graphql:schema": "npx ts-node --esm apps/backend/src/scripts/generate-schema.ts",
    "codegen:web": "cd apps/web && npx graphql-codegen",
    "codegen": "npm run codegen:web",
    "prebuild": "npm run codegen",
    "demo:broker-admin": "bash demos/export-broker-admin.sh",
    "postinstall": "nx connect"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
