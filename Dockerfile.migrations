# Migrations runner - runs TypeORM migrations
FROM node:22-alpine

# Install pnpm globally
RUN npm install -g pnpm

WORKDIR /app

# Copy source
COPY . .

# Install dependencies with pnpm
RUN pnpm install --frozen-lockfile --ignore-scripts

WORKDIR /app/apps/backend

# Run migrations
CMD ["pnpm", "exec", "typeorm", "migration:run", "-d", "src/config/typeorm.config.js"]
