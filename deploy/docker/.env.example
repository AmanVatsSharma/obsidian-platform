# ============================================================
# Obsidian Platform — Environment Variables
# Copy this to .env and fill in real values.
# DO NOT commit .env to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ────────────────────────────────────────────────────────────
POSTGRES_DB=obsidian
POSTGRES_USER=obsidian
# REQUIRED: strong password for PostgreSQL
POSTGRES_PASSWORD=changeme

# ────────────────────────────────────────────────────────────
# JWT AUTHENTICATION (REQUIRED)
# ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters, cryptographically random
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ────────────────────────────────────────────────────────────
# AWS (for SNS notifications, S3)
# ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# REQUIRED for push notifications / file storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────
NODE_ENV=production
SWAGGER_ENABLED=false
MARKET_DATA_PROVIDER=kite

# ────────────────────────────────────────────────────────────
# FRONTEND — Public URLs
# These are the URLs the browser will use to reach the API.
# Change these to your actual domain(s) in production.
# ────────────────────────────────────────────────────────────
# Internal Docker network URLs (used by frontends inside Docker)
NEXT_PUBLIC_API_URL=http://backend:3000
NEXT_PUBLIC_PRANA_WS_URL=ws://backend:3000/ws/prana

# ────────────────────────────────────────────────────────────
# DEV / TESTING (set to false in production)
# ────────────────────────────────────────────────────────────
OTP_DEV_MODE=false

# ────────────────────────────────────────────────────────────
# OPTIONAL — External integrations
# ────────────────────────────────────────────────────────────
# Kite Connect (Indian market data)
KITE_API_KEY=
KITE_API_SECRET=

# Email provider (SES, SendGrid, etc.)
EMAIL_PROVIDER=ses
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ────────────────────────────────────────────────────────────
# DEPLOYMENT NOTES
# ────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Set POSTGRES_PASSWORD to a strong random value
# 3. Generate JWT secrets: openssl rand -base64 32 (do this TWICE)
# 4. Set AWS keys if using push notifications / S3
# 5. Set KITE keys if using Indian market data
# 6. For Coolify: paste these as environment variables in the
#    service configuration UI instead of using a .env file.
# ============================================================