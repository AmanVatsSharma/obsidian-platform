# Migrations runner - runs TypeORM migrations
FROM node:22-alpine AS migrations

WORKDIR /app

COPY package*.json ./
RUN npm ci --ignore-scripts

COPY . .

# Run migrations using the actual TypeORM config location
WORKDIR /app/apps/backend
CMD ["sh", "-c", "npx ts-node --transpile-only -r tsconfig-paths/register src/shared/database/typeorm.config.ts && npx typeorm migration:run -d src/shared/database/typeorm.config.ts"]
