{
  "name": "obsidian-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/obsidian-ui/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:design-system", "layer:domain"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/obsidian-ui/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/obsidian-ui/jest.config.cjs",
        "passWithNoTests": false
      }
    }
  }
}
